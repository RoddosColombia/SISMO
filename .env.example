# ════════════════════════════════════════════════════
# RODDOS Contable IA — Variables de entorno
# Copia este archivo como backend/.env y frontend/.env
# y completa los valores reales.
# NUNCA subir el .env al repositorio.
# ════════════════════════════════════════════════════

# ── MongoDB ───────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=roddos_contable

# ── Alegra ERP ────────────────────────────────────
ALEGRA_EMAIL=email@empresa.com
ALEGRA_TOKEN=tu-token-de-alegra-aqui
ALEGRA_BASE_URL=https://app.alegra.com/api/r1/
ALEGRA_WEBHOOK_SECRET=tu-webhook-secret-aqui

# ── Auth / JWT ────────────────────────────────────
JWT_SECRET=tu-jwt-secret-muy-largo-y-seguro-aqui

# ── Anthropic / Emergent LLM ──────────────────────
EMERGENT_LLM_KEY=sk-ant-...

# ── App / CORS ────────────────────────────────────
APP_URL=https://tu-dominio.com
CORS_ORIGINS=http://localhost:3000
PORT=8001
DEMO_MODE=false

# ── Mercately (WhatsApp) ──────────────────────────
MERCATELY_API_KEY=tu-api-key-mercately-aqui
MERCATELY_STORE_ID=tu-store-id-aqui

# ── Frontend (crear frontend/.env) ───────────────
REACT_APP_BACKEND_URL=https://tu-dominio.com
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=true
SKIP_PREFLIGHT_CHECK=true
