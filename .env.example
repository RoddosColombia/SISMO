# ════════════════════════════════════════════════
# SISMO — RODDOS Contable IA
# Copiar este archivo como .env y completar los 
# valores reales. NUNCA subir el .env al repo.
# ════════════════════════════════════════════════

# ── Alegra ERP ────────────────────────────────
ALEGRA_EMAIL=
ALEGRA_TOKEN=
ALEGRA_BASE_URL=https://app.alegra.com/api/r1/

# ── MongoDB ───────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=roddos_contable

# ── Auth ──────────────────────────────────────
JWT_SECRET=

# ── Anthropic / Emergent LLM ──────────────────
EMERGENT_LLM_KEY=

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────
PORT=8001
DEMO_MODE=false

# ── Mercately (WhatsApp) ──────────────────────
MERCATELY_API_KEY=
MERCATELY_STORE_ID=
