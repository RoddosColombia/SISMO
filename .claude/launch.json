{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI + Uvicorn)",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "server:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001",
        "--reload"
      ],
      "port": 8001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "node_modules/@craco/craco/dist/bin/craco.js",
        "start"
      ],
      "port": 3000,
      "cwd": "frontend"
    }
  ]
}
